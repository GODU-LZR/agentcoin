{
  "node_id": "agentcoin-local",
  "name": "AgentCoin Reference Node",
  "description": "Cross-platform reference node with local queueing and secure ingress.",
  "host": "127.0.0.1",
  "port": 8080,
  "advertise_url": "http://100.64.0.1:8080",
  "auth_token": "change-me",
  "signing_secret": "replace-with-node-shared-secret",
  "require_signed_inbox": true,
  "auto_bootstrap_identity": true,
  "identity_principal": "agentcoin-local",
  "identity_private_key_path": "./var/identity/id_ed25519",
  "identity_auth_challenge_ttl_seconds": 300,
  "identity_auth_session_ttl_seconds": 900,
  "cors_allowed_origins": [
    "*"
  ],
  "operator_allow_loopback_bearer_fallback": false,
  "operator_auth_timestamp_skew_seconds": 300,
  "operator_auth_nonce_ttl_seconds": 900,
  "scoped_bearer_tokens": [
    {
      "token_id": "bearer:observer-local",
      "name": "Local Read-Only Automation Token",
      "token": "replace-with-read-only-bearer-token",
      "scopes": [
        "read-only"
      ],
      "source_restrictions": [
        "loopback-only"
      ],
      "enabled": true
    },
    {
      "token_id": "bearer:local-admin-local",
      "name": "Local Tier 1 Automation Token",
      "token": "replace-with-local-admin-bearer-token",
      "scopes": [
        "local-admin"
      ],
      "source_restrictions": [
        "loopback-only"
      ],
      "enabled": true
    },
    {
      "token_id": "bearer:workflow-local",
      "name": "Local Workflow Automation Token",
      "token": "replace-with-workflow-admin-bearer-token",
      "scopes": [
        "workflow-admin"
      ],
      "source_restrictions": [
        "loopback-only"
      ],
      "enabled": true
    }
  ],
  "operator_identities": [
    {
      "key_id": "read-only:observer-1",
      "name": "Local Read-Only Observer",
      "shared_secret": "replace-with-read-only-request-secret",
      "scopes": [
        "read-only"
      ],
      "source_restrictions": [
        "loopback-only"
      ],
      "enabled": true
    },
    {
      "key_id": "bridge-admin:ops-1",
      "name": "Local Bridge Admin",
      "shared_secret": "replace-with-bridge-admin-request-secret",
      "scopes": [
        "bridge-admin"
      ],
      "source_restrictions": [
        "loopback-only"
      ],
      "enabled": true
    },
    {
      "key_id": "workflow-admin:ops-1",
      "name": "Local Workflow Admin",
      "shared_secret": "replace-with-workflow-admin-request-secret",
      "scopes": [
        "workflow-admin"
      ],
      "source_restrictions": [
        "loopback-only"
      ],
      "enabled": true
    },
    {
      "key_id": "trust-admin:ops-1",
      "name": "Local Trust Admin",
      "shared_secret": "replace-with-trust-admin-request-secret",
      "scopes": [
        "trust-admin"
      ],
      "source_restrictions": [
        "loopback-only"
      ],
      "enabled": true
    },
    {
      "key_id": "settlement-admin:ops-1",
      "name": "Local Settlement Admin",
      "shared_secret": "replace-with-settlement-admin-request-secret",
      "scopes": [
        "settlement-admin"
      ],
      "source_restrictions": [
        "loopback-only"
      ],
      "enabled": true
    },
    {
      "key_id": "committee:reviewer-a",
      "name": "Committee Reviewer A",
      "shared_secret": "replace-with-committee-request-secret",
      "scopes": [
        "committee-member"
      ],
      "source_restrictions": [
        "loopback-only"
      ],
      "enabled": true
    }
  ],
  "database_path": "./var/agentcoin.db",
  "git_root": ".",
  "bridges": [
    "mcp",
    "a2a"
  ],
  "network": {
    "http_proxy": "http://127.0.0.1:10809",
    "https_proxy": "http://127.0.0.1:10809",
    "no_proxy_hosts": [
      "127.0.0.1",
      "localhost",
      "::1",
      "100.64.0.0/10",
      ".tailnet.internal"
    ],
    "use_environment_proxies": true
  },
  "onchain": {
    "enabled": true,
    "chain_id": 97,
    "rpc_url": "https://data-seed-prebsc-1-s1.bnbchain.org:8545",
    "explorer_base_url": "https://testnet.bscscan.com",
    "did_registry_address": "0x000000000000000000000000000000000000d1d0",
    "staking_pool_address": "0x00000000000000000000000000000000000057a0",
    "bounty_escrow_address": "0x000000000000000000000000000000000000b077",
    "local_did": "0x6167656e74636f696e2d6c6f63616c0000000000000000000000000000000000",
    "local_controller_address": "0x1111111111111111111111111111111111111111",
    "receipt_base_uri": "ipfs://agentcoin-receipts"
  },
  "sync_interval_seconds": 15,
  "settlement_relay_poll_seconds": 2,
  "settlement_relay_max_in_flight": 1,
  "max_body_bytes": 262144,
  "outbox_max_attempts": 5,
  "task_retry_limit": 3,
  "task_retry_backoff_seconds": 5,
  "local_dispatch_fallback": true,
  "dispatch_peer_cooldown_seconds": 60,
  "dispatch_peer_blacklist_after_failures": 4,
  "dispatch_peer_blacklist_seconds": 300,
  "dispatch_weak_network_penalty_cap": 120,
  "dispatch_backlog_penalty_cap": 120,
  "overlay_network": "tailnet",
  "overlay_endpoint": "agentcoin-a.tailnet.internal:8080",
  "overlay_addresses": [
    "100.64.0.1"
  ],
  "capabilities": [
    "task-routing",
    "offline-queue",
    "agent-card",
    "secure-ingress"
  ],
  "tags": [
    "reference",
    "cross-platform",
    "offline-first"
  ],
  "runtimes": [
    "python"
  ],
  "peers": [
    {
      "peer_id": "agentcoin-peer-b",
      "name": "AgentCoin Peer B",
      "url": "http://100.64.0.2:8080",
      "auth_token": "peer-b-token",
      "signing_secret": "replace-with-peer-b-shared-secret",
      "identity_principal": "agentcoin-peer-b",
      "identity_public_key": "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIEXAMPLEPEERPUBLICKEY agentcoin-peer-b",
      "identity_public_keys": [
        "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIEXAMPLENEXTPUBLICKEY agentcoin-peer-b-next"
      ],
      "identity_revoked_public_keys": [
        "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIEXAMPLERETIREDPUBLICKEY agentcoin-peer-b-old"
      ],
      "overlay_endpoint": "agentcoin-b.tailnet.internal:8080",
      "overlay_addresses": [
        "100.64.0.2"
      ],
      "tags": [
        "tailnet",
        "worker"
      ],
      "enabled": true
    }
  ]
}
